// test.cm — basic integer arithmetic, declaration, assignment, print
// Updated for Project 3: code lives inside Master()

int globalX;   // global variable — accessible from any function

function Master() returns nothing
{
    int x;
    int y;

    x = 10;
    y = 20;
    int z = x + y;
    print(z);       // 30

    x = z + 5;
    print(x);       // 35

    y = x + y + z;
    print(y);       // 85

    globalX = x;
    return;
}

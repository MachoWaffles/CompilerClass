// test.cm — basic integer arithmetic, declaration, assignment, print
// Updated for Project 3: code lives inside Master()

float globalX;   // global variable — accessible from any function

function Master() returns nothing
{
    float x;
    int y;

    bool s = true;

    x = 10.0;
    y = 20;

    char c = 'g';
    float z = (y/x*10) / (3.0 * y);
    print(z);       // 0.33333334

    x = z * 2;
    print(x);       // 0.66666668

    print(y);       // 20

    print(s);       // true

    print(c + x);
    globalX = x;
    return;
}

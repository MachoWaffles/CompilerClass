/* ================================================================
   FOR LOOP COMPREHENSIVE TEST FILE
   Tests every meaningful combination the grammar supports.
   Expected output is listed above each test as a comment.
   ================================================================ */


/* ----------------------------------------------------------------
   TEST 1: Basic count-up loop with i++
   Expected output: 0 1 2 3 4
   ---------------------------------------------------------------- */
function Test1() returns nothing
{
    for(int i = 0; i < 5; i++)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 2: Count-up with <= (should include 5)
   Expected output: 0 1 2 3 4 5
   ---------------------------------------------------------------- */
function Test2() returns nothing
{
    for(int i = 0; i <= 5; i++)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 3: Manual update (i = i + 2, step by 2)
   Expected output: 0 2 4 6 8
   ---------------------------------------------------------------- */
function Test3() returns nothing
{
    for(int i = 0; i < 10; i = i + 2)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 4: Loop body with arithmetic — print i * i (squares)
   Expected output: 0 1 4 9 16
   ---------------------------------------------------------------- */
function Test4() returns nothing
{
    for(int i = 0; i < 5; i++)
    {
        int sq = i * i;
        print(sq);
    }
}


/* ----------------------------------------------------------------
   TEST 5: Loop with a pre-declared counter (assign init, not decAssign)
   Expected output: 10 11 12 13 14
   ---------------------------------------------------------------- */
function Test5() returns nothing
{
    int j = 10;
    for(j = 10; j < 15; j++)
    {
        print(j);
    }
}


/* ----------------------------------------------------------------
   TEST 6: Accumulator — sum 1..5 inside a loop
   Expected output: 15
   ---------------------------------------------------------------- */
function Test6() returns nothing
{
    int sum = 0;
    for(int i = 1; i <= 5; i++)
    {
        sum = sum + i;
    }
    print(sum);
}


/* ----------------------------------------------------------------
   TEST 7: Nested for loops (multiplication table 1..3 x 1..3)
   Expected output: 1 2 3 2 4 6 3 6 9
   ---------------------------------------------------------------- */
function Test7() returns nothing
{
    for(int i = 1; i <= 3; i++)
    {
        for(int j = 1; j <= 3; j++)
        {
            int product = i * j;
            print(product);
        }
    }
}


/* ----------------------------------------------------------------
   TEST 8: For loop using == condition (runs exactly once when i starts = 0)
   Expected output: 0
   ---------------------------------------------------------------- */
function Test8() returns nothing
{
    for(int i = 0; i == 0; i++)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 9: For loop with != condition
   Expected output: 0 1 2 3 4
   ---------------------------------------------------------------- */
function Test9() returns nothing
{
    for(int i = 0; i != 5; i++)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 10: For loop with >= condition (counts down via manual update)
   Start at 5, subtract 1 each step, stop when i < 0 (i >= 0 is condition)
   Expected output: 5 4 3 2 1 0
   ---------------------------------------------------------------- */
function Test10() returns nothing
{
    for(int i = 5; i >= 0; i = i - 1)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 11: For loop with > condition
   Expected output: 4 3 2 1
   ---------------------------------------------------------------- */
function Test11() returns nothing
{
    for(int i = 4; i > 0; i = i - 1)
    {
        print(i);
    }
}


/* ----------------------------------------------------------------
   TEST 12: For loop that never executes (condition false from the start)
   Expected output: (nothing — loop body never runs)
   Followed by: 99  (proves execution continues past the loop)
   ---------------------------------------------------------------- */
function Test12() returns nothing
{
    for(int i = 10; i < 5; i++)
    {
        print(i);
    }
    print(99);
}


/* ----------------------------------------------------------------
   TEST 13: For loop reading/writing an array
   Fill arr[0..4] = i*2, then print each element
   Expected output: 0 2 4 6 8
   ---------------------------------------------------------------- */
function Test13() returns nothing
{
    int arr[5];
    for(int i = 0; i < 5; i++)
    {
        arr[i] = i * 2;
    }
    for(int i = 0; i < 5; i++)
    {
        print(arr[i]);
    }
}


/* ----------------------------------------------------------------
   TEST 14: For loop calling a function in its body
   add(a, b) returns a + b; loop prints add(i, 10) for i = 0..4
   Expected output: 10 11 12 13 14
   ---------------------------------------------------------------- */
function add(int a, int b) returns int
{
    return a + b;
}

function Test14() returns nothing
{
    for(int i = 0; i < 5; i++)
    {
        int result = add(i, 10);
        print(result);
    }
}


/* ----------------------------------------------------------------
   TEST 15: For loop inside a function that itself returns a value
   Sum 1..n and return it; called with n=5, expected print: 15
   ---------------------------------------------------------------- */
function sumTo(int n) returns int
{
    int total = 0;
    for(int i = 1; i <= n; i++)
    {
        total = total + i;
    }
    return total;
}

function Test15() returns nothing
{
    int s = sumTo(5);
    print(s);
}


/* ================================================================
   MASTER — runs all tests in order
   ================================================================ */
function Master() returns nothing
{
    Test1();
    Test2();
    Test3();
    Test4();
    Test5();
    Test6();
    Test7();
    Test8();
    Test9();
    Test10();
    Test11();
    Test12();
    Test13();
    Test14();
    Test15();
}

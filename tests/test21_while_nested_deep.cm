function Master() returns nothing {

    int i = 1;

    while (i < 3) {

        int j = 1;

        while (j < 3) {

            int k = 1;

            while (k < 3) {

                print(k);
                k = k + 1;

            }

            j = j + 1;
        }

        i = i + 1;
    }
}

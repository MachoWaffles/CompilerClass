// t18_structs_multiple.cm — two struct types, two struct vars, int between
// Expected output: 3  4  100  200
struct Vec2 {
    int x;
    int y;
}
struct Rect {
    int width;
    int height;
}
function Master() returns nothing {
    Vec2 v;
    v.x = 3;
    v.y = 4;
    print(v.x);
    print(v.y);
    Rect r;
    r.width  = 100;
    r.height = 200;
    print(r.width);
    print(r.height);
}

// t09_for_basic.cm — for loops: count up, step by 2, count down
// Expected output: 0 1 2 3 4  then  0 2 4 6 8  then  5 4 3 2 1 0
function Master() returns nothing {
    for(int i = 0; i < 5; i++) {
        print(i);
    }
    for(int i = 0; i < 10; i = i + 2) {
        print(i);
    }
    for(int i = 5; i >= 0; i = i - 1) {
        print(i);
    }
}

// t10_for_advanced.cm — for accumulator, nested for, zero-trip loop
// Expected output: 15  then  1 2 3 2 4 6 3 6 9  then  99
function Master() returns nothing {
    int total = 0;
    for(int i = 1; i <= 5; i++) {
        total = total + i;
    }
    print(total);
    for(int i = 1; i <= 3; i++) {
        for(int j = 1; j <= 3; j++) {
            int p = i * j;
            print(p);
        }
    }
    for(int i = 10; i < 5; i++) {
        print(i);
    }
    print(99);
}

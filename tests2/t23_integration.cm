// t23_integration.cm — all features: types, globals, functions, loops, arrays, structs
// Expected output: 5  10  1  65  15  0 1 2 3 4  55  7
struct Counter {
    int value;
    int step;
}
int globalSeed = 5;
function addInts(int a, int b) returns int {
    return a + b;
}
function Master() returns nothing {
    print(globalSeed);
    globalSeed = globalSeed + 5;
    print(globalSeed);
    bool flag = true;
    print(flag);
    char letter = 'A';
    print(letter);
    int s = addInts(7, 8);
    print(s);
    for(int i = 0; i < 5; i++) {
        print(i);
    }
    int acc = 0;
    int k = 1;
    while(k <= 10) {
        acc = acc + k;
        k = k + 1;
    }
    print(acc);
    Counter c;
    c.value = 7;
    c.step  = 3;
    print(c.value);
}
